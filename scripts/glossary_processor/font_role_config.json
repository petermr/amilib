          "coordinate_rules": {
            "x0_range": {
              "min": 130.0,
              "max": 449.0
            }
          }
        },
        "cross_reference": {
          "font_family_patterns": ["FrutigerLTPro-CondensedIta"]
        }
      },
      "annex-i-glossary": {
